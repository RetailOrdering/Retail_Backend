  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;User=root;Password=swap"
  },
  "JwtSettings": {
    "SecretKey": "YOUR_SUPER_SECRET_KEY_MIN_32_CHARS_LONG",
    "Issuer": "RetailOrdering.API",
    "Audience": "RetailOrdering.Client",
    "ExpiryHours": "24"
  },
  "SmtpSettings": {
    "Host": "smtp.gmail.com",
    "Port": "587",
    "Username": "your-email@gmail.com",
    "Password": "your-app-password",
    "FromName": "Retail Ordering"
  },
  "RateLimiting": {
    "RequestLimit": 100,
    "WindowSeconds": 60
  }

}
